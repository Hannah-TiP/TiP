{
  "name": "tip-travel",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"e2e/**/*.ts\" \"*.{ts,mjs}\"",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"e2e/**/*.ts\" \"*.{ts,mjs}\"",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "lighthouse": "lhci autorun",
    "analyze": "ANALYZE=true next build",
    "bundle-check": "node scripts/check-bundle-size.js",
    "ci": "npm run format:check && npm run lint && tsc --noEmit && npm run test && npm run build && npm run bundle-check && CI_MODE=1 npm run test:e2e && npm run lighthouse"
  },
  "dependencies": {
    "@paypal/react-paypal-js": "^8.9.2",
    "@react-google-maps/api": "^2.20.8",
    "@react-oauth/google": "^0.13.4",
    "axios": "^1.13.5",
    "form-data": "^4.0.5",
    "next": "16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@next/bundle-analyzer": "^16.1.6",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
